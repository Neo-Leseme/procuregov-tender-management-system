<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>ProcureGov — Ministry of Public Works Tender Management</display-name>
  <description>Digital Tender Management System for the Kingdom of Lesotho</description>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <context-param>
    <param-name>maxFileSizeMB</param-name>
    <param-value>10</param-value>
  </context-param>

  <!-- Uploaded documents are stored outside the deployed WAR.
       Change this path to a writable folder on your machine/server. -->
  <context-param>
    <param-name>uploadDir</param-name>
    <param-value>/tmp/procuregov-uploads</param-value>
  </context-param>

  <!-- AuthServlet -->
  <servlet>
    <servlet-name>AuthServlet</servlet-name>
    <servlet-class>com.controller.AuthServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/forgot-password</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/verify-code</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AuthServlet</servlet-name>
    <url-pattern>/reset-password</url-pattern>
  </servlet-mapping>

  <!-- TenderServlet — multipart-config required for Part API file upload -->
  <servlet>
    <servlet-name>TenderServlet</servlet-name>
    <servlet-class>com.controller.TenderServlet</servlet-class>
    <multipart-config>
      <max-file-size>5242880</max-file-size>
      <max-request-size>6291456</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/dashboard</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/tenders</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/tender/create</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/tender/edit</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/tender/detail</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TenderServlet</servlet-name>
    <url-pattern>/officer/tender/status</url-pattern>
  </servlet-mapping>

  <!-- BidServlet — multipart-config raised above 10MB so Tomcat does not
       reject the request before BidServlet runs. The 10MB business rule
       is enforced inside BidServlet code. -->
  <servlet>
    <servlet-name>BidServlet</servlet-name>
    <servlet-class>com.controller.BidServlet</servlet-class>
    <multipart-config>
      <max-file-size>15728640</max-file-size>
      <max-request-size>16777216</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>BidServlet</servlet-name>
    <url-pattern>/supplier/dashboard</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>BidServlet</servlet-name>
    <url-pattern>/supplier/tenders</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>BidServlet</servlet-name>
    <url-pattern>/supplier/tender/detail</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>BidServlet</servlet-name>
    <url-pattern>/supplier/bid/submit</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>BidServlet</servlet-name>
    <url-pattern>/supplier/award-notice</url-pattern>
  </servlet-mapping>

  <!-- EvalServlet — handles evaluation committee scoring AND
       officer award panel (/officer/eval/panel) AND
       award form submission (/officer/tender/award) -->
  <servlet>
    <servlet-name>EvalServlet</servlet-name>
    <servlet-class>com.controller.EvalServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EvalServlet</servlet-name>
    <url-pattern>/eval/dashboard</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>EvalServlet</servlet-name>
    <url-pattern>/eval/panel</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>EvalServlet</servlet-name>
    <url-pattern>/eval/score/submit</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>EvalServlet</servlet-name>
    <url-pattern>/officer/eval/panel</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>EvalServlet</servlet-name>
    <url-pattern>/officer/tender/award</url-pattern>
  </servlet-mapping>

  <!-- FileDownloadServlet -->
  <servlet>
    <servlet-name>FileDownloadServlet</servlet-name>
    <servlet-class>com.controller.FileDownloadServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>FileDownloadServlet</servlet-name>
    <url-pattern>/files/download</url-pattern>
  </servlet-mapping>

  <!-- NotifyServlet -->
  <servlet>
    <servlet-name>NotifyServlet</servlet-name>
    <servlet-class>com.controller.NotifyServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NotifyServlet</servlet-name>
    <url-pattern>/notify/award</url-pattern>
  </servlet-mapping>

  <!-- JNDI DataSource -->
  <resource-ref>
    <description>MySQL DataSource for ProcureGov via XAMPP on Ubuntu</description>
    <res-ref-name>jdbc/ProcureGovDB</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>

  <!-- Session configuration -->
  <session-config>
    <session-timeout>30</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <secure>false</secure>
    </cookie-config>
  </session-config>

  <!-- Custom error pages -->
  <error-page>
    <error-code>400</error-code>
    <location>/WEB-INF/views/common/error400.jsp</location>
  </error-page>
  <error-page>
    <error-code>403</error-code>
    <location>/WEB-INF/views/common/error403.jsp</location>
  </error-page>
  <error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/views/common/error404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/WEB-INF/views/common/error500.jsp</location>
  </error-page>
  <error-page>
    <exception-type>java.lang.Exception</exception-type>
    <location>/WEB-INF/views/common/error500.jsp</location>
  </error-page>

</web-app>