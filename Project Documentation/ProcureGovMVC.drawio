        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-41" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;AuthServlet&lt;br&gt;/login  /logout  /register&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• SHA-256 password verify&lt;br&gt;• Session creation (role-based)&lt;br&gt;• Login lockout (3 attempts)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="511" width="390" height="90" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-42" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;TenderServlet  [@MultipartConfig 5MB]&lt;br&gt;/officer/dashboard  /officer/tenders&lt;br&gt;/officer/tender/create|edit|detail|status&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• CRUD tenders (DRAFT only editable)&lt;br&gt;• PDF notice upload (Part API)&lt;br&gt;• Auto-appoints evaluators on UNDER_EVALUATION&lt;br&gt;• Timezone: Africa/Maseru via context.xml&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="626" width="390" height="120" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-43" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;BidServlet  [@MultipartConfig 15MB]&lt;br&gt;/supplier/dashboard  /supplier/tenders&lt;br&gt;/supplier/tender/detail  /supplier/bid/submit&lt;br&gt;/supplier/award-notice&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• One bid per tender enforcement&lt;br&gt;• Server-side closing date check (LocalDateTime)&lt;br&gt;• Bid document upload (PDF/DOCX ≤10MB)&lt;br&gt;• POST-Redirect-GET on success&lt;/font&gt;" style="rounded=1;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="771" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-44" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;EvalServlet&lt;br&gt;/eval/dashboard  /eval/panel  /eval/score/submit&lt;br&gt;/officer/eval/panel  /officer/tender/award&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• Scoring: technical (manual) + price + timeline (auto)&lt;br&gt;• Weighted Total = (P×0.40)+(T×0.35)+(TL×0.25)&lt;br&gt;• Leaderboard hidden until ALL 4 evaluators done&lt;br&gt;• Auto-transition UNDER_EVAL → EVALUATED&lt;br&gt;• System picks highest score — officer confirms&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="926" width="390" height="140" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-45" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;FileDownloadServlet&lt;br&gt;/files/download?type=notice|bid&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• Streams files without exposing filesystem paths&lt;br&gt;• Suppliers: own bid docs only&lt;br&gt;• Officers + Eval: any bid document&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="1091" width="390" height="90" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-46" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;NotifyServlet&lt;br&gt;/notify/award&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• JavaMail via Gmail SMTP + STARTTLS&lt;br&gt;• Sends AWARDED / NOT_AWARDED emails&lt;br&gt;• Auto-fires on award; officer can resend&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1044" y="1206" width="390" height="90" as="geometry" />
        </mxCell>
        <mxCell id="35xh7C9_-aYywN-wlrjo-47" value="com.util  —  Utility Classes" style="text;html=1;fillColor=light-dark(#6A00FF,#6600CC);fontColor=#ffffff;strokeColor=#3700CC;rounded=1;fontSize=10;fontStyle=1;align=left;spacingLeft=6;" parent="1" vertex="1">
