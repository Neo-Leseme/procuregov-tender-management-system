        <mxCell id="35xh7C9_-aYywN-wlrjo-40" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;awardNotice.jsp&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
