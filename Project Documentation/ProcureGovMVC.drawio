        <mxCell id="35xh7C9_-aYywN-wlrjo-48" value="&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;SessionUtil  —  auth checks, role redirects, flash messages&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=light-dark(#6A00FF,#6600CC);fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
